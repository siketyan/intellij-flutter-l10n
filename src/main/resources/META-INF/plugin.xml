<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>jp.s6n.idea.flutter.l10n</id>
    <name>Flutter Localizations</name>
    <vendor>Naoki Ikeguchi</vendor>
    <description><![CDATA[
        <p>Shows Flutter localization messages from ARB files directly in Dart code as folding placeholders.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>Dart</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="ARB"
                extensions="arb"
                implementationClass="jp.s6n.idea.flutter.l10n.ArbFileType"
                fieldName="INSTANCE"
                language="JSON"/>
        <lang.foldingBuilder
                language="Dart"
                implementationClass="jp.s6n.idea.flutter.l10n.folding.FlutterL10nFoldingBuilder"/>
    </extensions>
</idea-plugin>
